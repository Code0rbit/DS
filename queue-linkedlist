#include <iostream>
using namespace std;
class Node {
public:
    int data;
    Node* next;
    Node(int new_data) {
        data = new_data;
        next = nullptr;
    }
};
class myQueue {
private:
    int currSize;
    Node* front;
    Node* rear;

public:
    myQueue() {
        currSize = 0;
        front = rear= nullptr;
    }
    bool isEmpty() {
        return front == nullptr;
    }
    void enqueue(int new_data) {
        Node* node = new Node(new_data);
        if (isEmpty()) {
            front = rear = node;
        } else {
            rear->next = node;
            rear = node;
        }
        
        currSize++;
    }
    int dequeue() {
        if (isEmpty()) {
            cout << "Queue Underflow" << endl;
            return -1;
        }
        
        Node* temp = front;
        int removedData = temp->data;
        front = front->next;
        
        if (front == nullptr) rear = nullptr;
        delete temp;
        
        currSize--;
        return removedData;
    }
    int getfront() {
        if (isEmpty()) {
            cout << "Queue is empty" << endl;
            return -1;
        }
        return front->data;
    }
    int size() {
       return currSize;
    }
};

int main() {
    myQueue q;
    
    q.enqueue(10);
    q.enqueue(20);

    cout << "Dequeue: " << q.dequeue() << "\n";
    
    q.enqueue(30);

    cout << "Front: " << q.getfront() << endl;
    cout << "Size: " << q.size() << endl;

    return 0;
}
